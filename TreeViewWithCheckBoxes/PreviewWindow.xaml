<Window x:Class="GenQ.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenQ" d:DataContext="{d:DesignInstance Type=local:ExcelGen}"
        Icon="Resources\GenQLogo.ico"
        mc:Ignorable="d"
        Title="GenQ | Export Options"  Height="400" MinHeight="400" MinWidth="650" Width="850" ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <ResourceDictionary>

            <Style
        x:Key="ButtonFocusVisual">
                <Setter
            Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Rectangle Margin="2" SnapsToDevicePixels="true" Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" StrokeThickness="1" StrokeDashArray="1 2" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="MetroButton" TargetType="{x:Type Button}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource ButtonFocusVisual}"/>
                <Setter Property="Background" Value="#ADADAD"/>
                <Setter Property="Foreground" Value="#7F8C8D"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="10 5"/>
                <Setter Property="FontSize" Value="14" />
                <Setter Property="BorderThickness" Value="2" />

                <Setter Property="Template">

                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Grid>
                                <Border
                                x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">

                                </Border>

                                <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                RecognizesAccessKey="True" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="OpacityMask" Value="#AA888888"/>
                                    <Setter Property="Margin" Value="2 1" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <!--<Setter Property="Background" Value="DimGray"/>-->
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="false">
                                    <Setter Property="Foreground" Value="#ADADAD"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="TextBoxx" TargetType="{x:Type RichTextBox}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RichTextBox}">

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Width" Value="300"/>
                                    <Setter Property="Height" Value="300"/>

                                    <!--<Setter Property="Background" Value="DimGray"/>-->
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="True">
                                    <Setter Property="Foreground" Value="#ADADAD"/>
                                    <Setter Property="Width" Value="400"/>
                                    <Setter Property="Height" Value="400"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>


        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="215"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Background="#5F6A6A" >
            <Border BorderThickness="1.5" BorderBrush="#424949" CornerRadius="6" Background="LightGray" Margin="4 4 4 4">
                <Grid>
                    <Grid.RowDefinitions>

                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="250"/>


                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" >
                        <Button HorizontalAlignment="Right" FontSize="5" 
                                     BorderThickness="1" Margin="10,0,0,0" VerticalAlignment="Center" 
                                    Style="{StaticResource MetroButton}" Padding="2" Click="ClientLogo_Button" >

                            <Path Data="M0.5,0 L0.5,1 M0,0.5 L1,0.5" StrokeThickness="1" Stretch="Fill" Stroke="#424445"
                                      StrokeEndLineCap="Square" StrokeStartLineCap="Square" Height="10" Width="10" />
                            <Button.ToolTip>
                                <Image x:Name="imgclient"/>
                            </Button.ToolTip>

                        </Button>
                        <TextBlock Text="Add Client Logo" VerticalAlignment="Center" Margin="5 0 0 0" Foreground="Black"  />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="1">
                        <Button HorizontalAlignment="Right" FontSize="5" 
                                     BorderThickness="1" Margin="10,0,0,0" VerticalAlignment="Center" 
                                    Style="{StaticResource MetroButton}" Padding="2" Click="CreatorLogo_Button"    >

                            <Path Data="M0.5,0 L0.5,1 M0,0.5 L1,0.5" StrokeThickness="1" Stretch="Fill" Stroke="#424445"
                                      StrokeEndLineCap="Square" StrokeStartLineCap="Square" Height="10" Width="10" />
                            <Button.ToolTip>
                                <Image x:Name="imgcreator"/>
                            </Button.ToolTip>
                        </Button>
                        <TextBlock Text="Add Creator Logo" VerticalAlignment="Center" Margin="5 0 0 0" Foreground="Black"  />
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Stretch">
                        <TextBlock Text="Project Name" VerticalAlignment="Center" Margin="5 0 0 0"/>
                        <TextBox MaxLength="50" TextChanged="TextBox_TextChanged" Text="{Binding Path=ProjectName , Mode=TwoWay}" HorizontalAlignment="Left" Width="100" Height="20" Margin="20 0 0 0"></TextBox>
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Stretch">
                        <TextBlock Text="Project Location" VerticalAlignment="Center" Margin="5 0 0 0"/>
                        <TextBox MaxLength="50" TextChanged="TextBox_TextChanged" Text="{Binding Path=ProjectLocation, Mode=TwoWay}" HorizontalAlignment="Left" Width="100" Height="20" Margin="7 0 0 0"></TextBox>
                    </StackPanel>
                    <StackPanel Grid.Row="5">
                        <Button BorderThickness="1" BorderBrush="#424445" Foreground="#D7DBDD" Background="#7F8C8D"  FontSize="10" Style="{StaticResource MetroButton}" 
                                Content="PDF Preview" HorizontalAlignment="Center"  VerticalAlignment="Center"  Margin="0 30 0 10" Width="120" Click="ClickPreview"/>
                        <Button  Click="Export_PDF_Button" BorderThickness="1" BorderBrush="#424445" Foreground="#D7DBDD" Background="#7F8C8D" FontSize="10" Style="{StaticResource MetroButton}" Content="Export to PDF" HorizontalAlignment="Center" Margin="0 0 0 10"  VerticalAlignment="Center" Width="120"/>
                        <Button  Click="Export_Excel_Button" BorderThickness="1" BorderBrush="#424445" Foreground="#D7DBDD" Background="#7F8C8D" FontSize="10" Style="{StaticResource MetroButton}" Content="Export to Excel" HorizontalAlignment="Center" Margin="0 0 0 0"  VerticalAlignment="Center" Width="120"/>
                    </StackPanel>
                    <!--<Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button  BorderThickness="1" BorderBrush="#424445" Foreground="#D7DBDD" Background="#7F8C8D" FontSize="10" Style="{StaticResource MetroButton}" Content="Export Excel" HorizontalAlignment="Right" Margin="0 0 10 0"  VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"  Width="75"/>
                        <Button  BorderThickness="1" BorderBrush="#424445" Foreground="#D7DBDD" Background="#7F8C8D" FontSize="10" Style="{StaticResource MetroButton}" Content="Export PDF" HorizontalAlignment="Left" Margin="10 0 0 0"  VerticalAlignment="Center" Grid.Row="0" Grid.Column="1" Width="75"/>

                    </Grid>-->
                    <!--<Grid Grid.Row="4">
                        <Button BorderThickness="1" BorderBrush="#424445" Foreground="#D7DBDD" Background="#7F8C8D"  FontSize="10" Style="{StaticResource MetroButton}" 
                                Content="Preview" HorizontalAlignment="Center"  VerticalAlignment="Center"  Margin="0 0 0 0" Width="120"/>
                    </Grid>-->
                </Grid>
            </Border>

        </Grid>

        <Grid Grid.Column="1" Background="#5F6A6A" >
            <Border BorderThickness="1.5" BorderBrush="#424949" CornerRadius="6" Background="LightGray" Margin="4 4 4 4">
                <Grid>

                    <WebBrowser x:Name="pdfx"  Margin="2 2 2 2" />
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>
